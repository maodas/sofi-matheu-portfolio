---
interface Props {
  title: string;
  subtitle: string;
  date: string;
}
const { title, subtitle, date } = Astro.props;
---
<div class="relative pl-8 pb-12 border-l-[1px] border-terracotta last:border-transparent group">
  <span class="absolute -left-[5px] top-2 h-2.5 w-2.5 rounded-full bg-primary ring-4 ring-[#FAFAFA] shadow-sm transition-transform group-hover:scale-125"></span>
  
  <div class="flex flex-col mb-4">
    <span class="font-mono text-xs tracking-widest text-terracotta uppercase mb-2">{date}</span>
    <h3 class="font-serif text-2xl md:text-3xl font-bold text-earth-text mb-1 group-hover:text-primary transition-colors">{title}</h3>
    <h4 class="font-sans text-lg text-earth-text/80 font-medium">{subtitle}</h4>
  </div>
  
  <div class="text-earth-text/90 leading-relaxed font-sans max-w-3xl">
    <slot />
  </div>
</div>

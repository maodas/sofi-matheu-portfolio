---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="group border border-earth-text/10 hover:border-terracotta bg-white p-8 rounded-3xl shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
  <h3 class="text-2xl font-bold mb-2 group-hover:text-primary transition-colors text-earth-text leading-tight">{title}</h3>
  {subtitle && <p class="text-xl font-medium text-earth-text/70 mb-4">{subtitle}</p>}
  
  <div class="text-earth-text/90 leading-relaxed text-sm">
    <slot />
  </div>
</div>

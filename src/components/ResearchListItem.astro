---
interface Props {
  title: string;
  year: string;
}
const { title, year } = Astro.props;
---
<div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-2 sm:gap-6 py-6 border-b border-earth-text/10 group last:border-transparent">
  <h3 class="font-serif italic text-lg md:text-xl text-earth-text leading-relaxed flex-1 group-hover:text-primary transition-colors">
    {title}
  </h3>
  <span class="font-mono text-sm text-terracotta tracking-widest pt-1 shrink-0">
    {year}
  </span>
</div>
